{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Stratum DS — design tokens. Source of truth. CSS vars and Tailwind config are generated from this file.",
  "color": {
    "$description": "All colors in OKLCH for perceptual uniformity. Semantic tokens reference primitives; consumers should use semantic tokens unless creating new semantic tokens.",
    "surface": {
      "base":       { "$value": "oklch(0.165 0.006 255)", "$type": "color", "$description": "Page background" },
      "elevated":   { "$value": "oklch(0.205 0.007 255)", "$type": "color", "$description": "Header, sidebar, sticky chrome" },
      "raised":     { "$value": "oklch(0.235 0.008 255)", "$type": "color", "$description": "Cards, surfaces above page" },
      "raised-2":   { "$value": "oklch(0.275 0.009 255)", "$type": "color", "$description": "Inputs, table headers, nested surfaces" },
      "hover":      { "$value": "oklch(0.305 0.010 255)", "$type": "color", "$description": "Interactive hover state" }
    },
    "text": {
      "primary":    { "$value": "oklch(0.965 0.003 255)", "$type": "color" },
      "secondary":  { "$value": "oklch(0.78 0.006 255)",  "$type": "color" },
      "muted":      { "$value": "oklch(0.59 0.008 255)",  "$type": "color" },
      "disabled":   { "$value": "oklch(0.43 0.009 255)",  "$type": "color" }
    },
    "border": {
      "subtle":     { "$value": "oklch(0.285 0.009 255)", "$type": "color" },
      "default":    { "$value": "oklch(0.345 0.010 255)", "$type": "color" },
      "strong":     { "$value": "oklch(0.435 0.012 255)", "$type": "color" }
    },
    "brand": {
      "$description": "Primary defaults to Stratum Blue. Replace per project. Accent should harmonize with primary but never compete for attention.",
      "primary":         { "$value": "oklch(0.66 0.16 250)", "$type": "color" },
      "primary-hover":   { "$value": "oklch(0.71 0.16 250)", "$type": "color" },
      "primary-active":  { "$value": "oklch(0.60 0.16 250)", "$type": "color" },
      "primary-soft":    { "$value": "oklch(0.30 0.09 250)", "$type": "color", "$description": "Backgrounds for selected/active subtle states" },
      "primary-fg":      { "$value": "oklch(0.99 0.003 255)", "$type": "color", "$description": "Foreground used ON primary background — auto-flips for amber" },
      "accent":          { "$value": "oklch(0.72 0.14 305)", "$type": "color" }
    },
    "feedback": {
      "success":        { "$value": "oklch(0.72 0.15 150)", "$type": "color" },
      "success-soft":   { "$value": "oklch(0.30 0.07 150)", "$type": "color" },
      "warning":        { "$value": "oklch(0.80 0.14 80)",  "$type": "color" },
      "warning-soft":   { "$value": "oklch(0.32 0.07 80)",  "$type": "color" },
      "danger":         { "$value": "oklch(0.66 0.19 25)",  "$type": "color" },
      "danger-soft":    { "$value": "oklch(0.30 0.09 25)",  "$type": "color" },
      "info":           { "$value": "oklch(0.72 0.13 235)", "$type": "color" },
      "info-soft":      { "$value": "oklch(0.30 0.07 235)", "$type": "color" }
    },
    "chart": {
      "$description": "Categorical palette for data viz. Use in order. Perceptually distinct in both color and luminance for colorblind safety.",
      "1": { "$value": "oklch(0.66 0.16 250)", "$type": "color" },
      "2": { "$value": "oklch(0.72 0.14 305)", "$type": "color" },
      "3": { "$value": "oklch(0.72 0.15 150)", "$type": "color" },
      "4": { "$value": "oklch(0.80 0.14 80)",  "$type": "color" },
      "5": { "$value": "oklch(0.68 0.18 15)",  "$type": "color" },
      "6": { "$value": "oklch(0.72 0.13 200)", "$type": "color" },
      "7": { "$value": "oklch(0.68 0.17 340)", "$type": "color" },
      "8": { "$value": "oklch(0.78 0.10 100)", "$type": "color" }
    },
    "neutral": {
      "$description": "Generic neutral scale. Prefer semantic tokens; use this only when adding new semantic ones.",
      "50":  { "$value": "oklch(0.985 0.003 255)", "$type": "color" },
      "100": { "$value": "oklch(0.955 0.004 255)", "$type": "color" },
      "200": { "$value": "oklch(0.900 0.005 255)", "$type": "color" },
      "300": { "$value": "oklch(0.820 0.006 255)", "$type": "color" },
      "400": { "$value": "oklch(0.700 0.008 255)", "$type": "color" },
      "500": { "$value": "oklch(0.580 0.009 255)", "$type": "color" },
      "600": { "$value": "oklch(0.460 0.010 255)", "$type": "color" },
      "700": { "$value": "oklch(0.360 0.010 255)", "$type": "color" },
      "800": { "$value": "oklch(0.280 0.009 255)", "$type": "color" },
      "900": { "$value": "oklch(0.200 0.008 255)", "$type": "color" },
      "950": { "$value": "oklch(0.130 0.006 255)", "$type": "color" }
    }
  },
  "color-light": {
    "$description": "Light-mode overrides — applied under [data-stratum-theme=\"light\"]. Only the values that differ from dark.",
    "surface": {
      "base":     { "$value": "oklch(0.985 0.003 255)", "$type": "color" },
      "elevated": { "$value": "oklch(0.965 0.004 255)", "$type": "color" },
      "raised":   { "$value": "oklch(1.000 0 0)",       "$type": "color" },
      "raised-2": { "$value": "oklch(0.970 0.004 255)", "$type": "color" },
      "hover":    { "$value": "oklch(0.945 0.005 255)", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "oklch(0.205 0.012 255)", "$type": "color" },
      "secondary": { "$value": "oklch(0.380 0.010 255)", "$type": "color" },
      "muted":     { "$value": "oklch(0.520 0.008 255)", "$type": "color" },
      "disabled":  { "$value": "oklch(0.720 0.008 255)", "$type": "color" }
    },
    "border": {
      "subtle":  { "$value": "oklch(0.925 0.006 255)", "$type": "color" },
      "default": { "$value": "oklch(0.860 0.008 255)", "$type": "color" },
      "strong":  { "$value": "oklch(0.760 0.010 255)", "$type": "color" }
    },
    "brand": {
      "primary-soft": { "$value": "oklch(0.94 0.04 250)", "$type": "color" }
    },
    "feedback": {
      "success-soft": { "$value": "oklch(0.94 0.04 150)", "$type": "color" },
      "warning-soft": { "$value": "oklch(0.95 0.05 80)",  "$type": "color" },
      "danger-soft":  { "$value": "oklch(0.95 0.04 25)",  "$type": "color" },
      "info-soft":    { "$value": "oklch(0.95 0.04 235)", "$type": "color" }
    }
  },
  "accents": {
    "$description": "Alternative brand accents — switched via [data-accent]. Default is blue (already in color.brand).",
    "violet":  { "primary": { "$value": "oklch(0.68 0.17 300)" }, "primary-hover": { "$value": "oklch(0.73 0.17 300)" }, "primary-soft": { "$value": "oklch(0.30 0.09 300)" } },
    "emerald": { "primary": { "$value": "oklch(0.70 0.15 160)" }, "primary-hover": { "$value": "oklch(0.75 0.15 160)" }, "primary-soft": { "$value": "oklch(0.30 0.08 160)" } },
    "amber":   { "primary": { "$value": "oklch(0.80 0.14 80)" },  "primary-hover": { "$value": "oklch(0.84 0.14 80)" },  "primary-soft": { "$value": "oklch(0.35 0.08 80)" },  "primary-fg": { "$value": "oklch(0.15 0.01 80)" } },
    "rose":    { "primary": { "$value": "oklch(0.68 0.18 15)" },  "primary-hover": { "$value": "oklch(0.73 0.18 15)" },  "primary-soft": { "$value": "oklch(0.30 0.09 15)" } }
  },
  "space": {
    "$description": "Spacing scale. Base unit 4px. Every margin, padding, gap, and inset is a multiple.",
    "0":  { "$value": "0",     "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "20px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0",     "$type": "dimension" },
    "xs":   { "$value": "2px",   "$type": "dimension" },
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "md":   { "$value": "8px",   "$type": "dimension" },
    "lg":   { "$value": "12px",  "$type": "dimension" },
    "xl":   { "$value": "16px",  "$type": "dimension" },
    "2xl":  { "$value": "20px",  "$type": "dimension" },
    "full": { "$value": "999px", "$type": "dimension" }
  },
  "shadow": {
    "xs": { "$value": "0 1px 1px rgba(0,0,0,0.30)", "$type": "shadow" },
    "sm": { "$value": "0 1px 2px rgba(0,0,0,0.35), 0 1px 1px rgba(0,0,0,0.25)", "$type": "shadow" },
    "md": { "$value": "0 6px 16px rgba(0,0,0,0.40), 0 2px 4px rgba(0,0,0,0.30)", "$type": "shadow" },
    "lg": { "$value": "0 18px 40px rgba(0,0,0,0.45), 0 4px 8px rgba(0,0,0,0.30)", "$type": "shadow" },
    "xl": { "$value": "0 32px 72px rgba(0,0,0,0.55), 0 8px 16px rgba(0,0,0,0.35)", "$type": "shadow" }
  },
  "shadow-light": {
    "$description": "Lighter shadow set for light mode — applied under [data-stratum-theme=\"light\"].",
    "xs": { "$value": "0 1px 1px rgba(15,23,42,0.04)" },
    "sm": { "$value": "0 1px 2px rgba(15,23,42,0.05), 0 1px 1px rgba(15,23,42,0.04)" },
    "md": { "$value": "0 4px 12px rgba(15,23,42,0.08), 0 2px 4px rgba(15,23,42,0.04)" },
    "lg": { "$value": "0 12px 32px rgba(15,23,42,0.10), 0 4px 8px rgba(15,23,42,0.06)" },
    "xl": { "$value": "0 24px 64px rgba(15,23,42,0.16), 0 8px 16px rgba(15,23,42,0.08)" }
  },
  "z": {
    "base":     { "$value": 0,   "$type": "number" },
    "sticky":   { "$value": 10,  "$type": "number" },
    "dropdown": { "$value": 100, "$type": "number" },
    "overlay":  { "$value": 200, "$type": "number" },
    "modal":    { "$value": 300, "$type": "number" },
    "popover":  { "$value": 400, "$type": "number" },
    "toast":    { "$value": 500, "$type": "number" },
    "command":  { "$value": 700, "$type": "number" }
  },
  "duration": {
    "instant": { "$value": "100ms", "$type": "duration" },
    "fast":    { "$value": "160ms", "$type": "duration" },
    "base":    { "$value": "220ms", "$type": "duration" },
    "slow":    { "$value": "320ms", "$type": "duration" },
    "slower":  { "$value": "480ms", "$type": "duration" }
  },
  "easing": {
    "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)",   "$type": "cubicBezier" },
    "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" },
    "out":      { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
    "spring":   { "$value": "cubic-bezier(0.5, 1.4, 0.5, 1)", "$type": "cubicBezier" }
  },
  "typography": {
    "font-sans": { "$value": "Geist, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif", "$type": "fontFamily" },
    "font-mono": { "$value": "'Geist Mono', ui-monospace, 'SF Mono', Consolas, monospace", "$type": "fontFamily" },
    "font-serif": { "$value": "'Instrument Serif', ui-serif, Georgia, serif", "$type": "fontFamily", "$description": "Editorial accent. Use sparingly for hero treatments only." },
    "scale": {
      "display":  { "$value": { "fontSize": "60px", "lineHeight": "64px", "letterSpacing": "-0.035em", "fontWeight": 600 }, "$type": "typography" },
      "h1":       { "$value": { "fontSize": "40px", "lineHeight": "44px", "letterSpacing": "-0.025em", "fontWeight": 600 }, "$type": "typography" },
      "h2":       { "$value": { "fontSize": "30px", "lineHeight": "36px", "letterSpacing": "-0.02em",  "fontWeight": 600 }, "$type": "typography" },
      "h3":       { "$value": { "fontSize": "22px", "lineHeight": "28px", "letterSpacing": "-0.015em", "fontWeight": 600 }, "$type": "typography" },
      "h4":       { "$value": { "fontSize": "17px", "lineHeight": "22px", "letterSpacing": "-0.01em",  "fontWeight": 600 }, "$type": "typography" },
      "body-lg":  { "$value": { "fontSize": "17px", "lineHeight": "26px", "letterSpacing": "0",        "fontWeight": 400 }, "$type": "typography" },
      "body":     { "$value": { "fontSize": "14px", "lineHeight": "21px", "letterSpacing": "0",        "fontWeight": 400 }, "$type": "typography" },
      "small":    { "$value": { "fontSize": "12px", "lineHeight": "17px", "letterSpacing": "0",        "fontWeight": 400 }, "$type": "typography" },
      "label":    { "$value": { "fontSize": "11px", "lineHeight": "16px", "letterSpacing": "0.08em",   "fontWeight": 500, "textTransform": "uppercase" }, "$type": "typography" }
    }
  },
  "breakpoint": {
    "sm":  { "$value": "360px",  "$type": "dimension", "$description": "Mobile" },
    "md":  { "$value": "768px",  "$type": "dimension", "$description": "Tablet" },
    "lg":  { "$value": "1024px", "$type": "dimension", "$description": "Desktop" },
    "xl":  { "$value": "1440px", "$type": "dimension", "$description": "Large desktop" },
    "2xl": { "$value": "1920px", "$type": "dimension", "$description": "Ultra-wide" }
  }
}
